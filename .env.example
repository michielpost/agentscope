# AgentScope — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── WalletConnect ───────────────────────────────────────────────
# Get a free Project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── Uniswap ─────────────────────────────────────────────────────
# Get an API key at https://developer.uniswap.org
NEXT_PUBLIC_UNISWAP_API_KEY=your_uniswap_api_key_here
# Uniswap v3 subgraph (The Graph) — no key needed for public endpoint
NEXT_PUBLIC_UNISWAP_SUBGRAPH_URL=https://gateway.thegraph.com/api/[api-key]/subgraphs/id/5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV

# ─── Celo ────────────────────────────────────────────────────────
# Public Celo RPC — no key needed
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
# Blockscout API — no key needed
NEXT_PUBLIC_CELO_BLOCKSCOUT_URL=https://explorer.celo.org/mainnet/api

# ─── Bankr ───────────────────────────────────────────────────────
# Get your API key at https://bankr.bot
BANKR_API_KEY=your_bankr_api_key_here
NEXT_PUBLIC_BANKR_API_URL=https://api.bankr.bot

# ─── SuperRare / Rare Protocol ───────────────────────────────────
# SuperRare GraphQL API — public read endpoint
NEXT_PUBLIC_SUPERRARE_API_URL=https://api.superrare.com/graphql

# ─── Octant ──────────────────────────────────────────────────────
# Octant subgraph — public
NEXT_PUBLIC_OCTANT_SUBGRAPH_URL=https://api.studio.thegraph.com/query/58090/octant/version/latest
NEXT_PUBLIC_OCTANT_API_URL=https://backend.production.octant.app

# ─── Olas / Pearl ────────────────────────────────────────────────
# Olas backend API — public
NEXT_PUBLIC_OLAS_API_URL=https://backend.autonolas.tech
NEXT_PUBLIC_OLAS_REGISTRY_URL=https://registry.olas.network
